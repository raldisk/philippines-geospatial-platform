# ============================================================
# .env.example — PH Geospatial Intelligence Platform v2.2
# BYOD-ready configuration reference.
#
# cp .env.example .env
# Edit .env with your values — never commit .env to version control.
# ============================================================

# ── Pipeline identity ─────────────────────────────────────────────────────────
GEO_DATASET_NAME=psa_provincial_2023

# ── File paths ────────────────────────────────────────────────────────────────
GEO_DATA_DIR=data
GEO_OUTPUT_DIR=outputs/day2
GEO_CURATED_PARQUET=data/curated/curated.parquet
ARCHIVE_LOCAL_STAGING=/tmp/geo_staging

# ── MinIO / S3 ────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=http://minio:9000
# Upload bucket (sensor target — where users upload .7z archives)
MINIO_BUCKET=geospatial-archives
GEO_UPLOAD_BUCKET=geo-uploads
MINIO_ARCHIVE_PREFIX=uploads/

# Medallion layer buckets (overridable for cloud S3 deployments)
GEO_BRONZE_BUCKET=geo-bronze
GEO_SILVER_TEMP_BUCKET=geo-silver-tmp
GEO_GOLD_BUCKET=geo-gold

# MinIO credentials — use Docker Secrets in production (MINIO_ACCESS_KEY_FILE)
# MINIO_ACCESS_KEY=<your-access-key>
# MINIO_SECRET_KEY=<your-secret-key>

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Use Docker Secret (POSTGRES_DSN_FILE) in production.
# For local dev only:
# POSTGRES_DSN=postgresql://geo_pipeline_role:<password>@localhost:5432/geo_platform

# ── CRS / projection (BYOD-03) ───────────────────────────────────────────────
# Fallback CRS when shapefile has no .prj file or CRS is unreadable.
# EPSG:4326 = WGS84 geographic (default — universal)
# EPSG:32651 = UTM Zone 51N (Philippine engineering surveys)
TARGET_CRS=EPSG:4326

# ── Column name mapping (BYOD — non-PSA shapefiles) ─────────────────────────
# JSON mapping of canonical roles → actual column names in your shapefile.
# Default: PSA/NAMRIA ADM naming convention.
# Override example for GADM shapefiles:
#   REGION_COLUMN_MAP={"region":"NAME_1","province":"NAME_2","city":"NAME_3","barangay":"NAME_4"}
REGION_COLUMN_MAP={"region":"ADM1_EN","province":"ADM2_EN","city":"ADM3_EN","barangay":"ADM4_EN"}

# ── Layer filter (multi-shapefile archives) ───────────────────────────────────
# Comma-separated shapefile stems to ingest when archive contains multiple .shp.
# Empty = ingest all shapefiles found.
# Example: LAYER_FILTER=Provinces,Municipalities
LAYER_FILTER=

# ── Silver worker limits (BYOD-06 / memory safety) ───────────────────────────
# SILVER_MAX_WORKERS=1  for machines with <4GB RAM or archives >500MB.
# SILVER_MAX_WORKERS=4  default (matches ProcessPoolExecutor partition count).
SILVER_MAX_WORKERS=4
SILVER_MEMORY_LIMIT_MB=4096

# ── H3 / Jenks ────────────────────────────────────────────────────────────────
H3_MIN_OCCUPANCY_RATIO=0.70
H3_MIN_FEATURES_PER_HEX=2
JENKS_CLASSES=5

# ── Tile parameters ───────────────────────────────────────────────────────────
TILE_MIN_ZOOM=4
TILE_MAX_ZOOM=12

# ── API ───────────────────────────────────────────────────────────────────────
GEO_VALUE_COLUMN=poverty_rate
MARTIN_BASE_URL=http://martin:3002
TILE_DATASET=ph_boundaries

# Rate limits (requests per minute) — override per deployment needs
RATE_LIMIT_GEOJSON=50/minute
RATE_LIMIT_H3=100/minute

# Accepted H3 resolutions (comma-separated). Empty = all 0–15.
# Example: VALID_H3_RESOLUTIONS=5,6,7  (restrict to standard PH analysis resolutions)
VALID_H3_RESOLUTIONS=

# Bounding box envelope for H3/GeoJSON queries (override for sub-national datasets)
TARGET_BBOX_LON_MIN=116.0
TARGET_BBOX_LON_MAX=127.0
TARGET_BBOX_LAT_MIN=4.5
TARGET_BBOX_LAT_MAX=22.0

# ── Logging ───────────────────────────────────────────────────────────────────
GEO_LOG_LEVEL=INFO
GEO_LOG_JSON=0

# ── Observability ─────────────────────────────────────────────────────────────
PUSHGATEWAY_URL=http://pushgateway:9091

# ── Tippecanoe (binary integrity) ─────────────────────────────────────────────
TIPPECANOE_BIN=/usr/local/bin/tippecanoe
PMTILES_BIN=/usr/local/bin/pmtiles
TIPPECANOE_VERSION=2.67.0
# Obtain with: curl -fsSL <tippecanoe-url> | sha256sum
# Must be set in CI via GitHub secret TIPPECANOE_SHA256
TIPPECANOE_SHA256=UNSET
# Set to 1 to skip SHA-256 check in local dev only — never in CI
TIPPECANOE_SKIP_SHA256=0
